# ── GitHub ────────────────────────────────────────────────────────────────────
# Personal access token with repo + read:org scopes
GITHUB_TOKEN=ghp_your_token_here

# One or more repos to pull data from (comma-separated: org/repo,org/repo2)
GITHUB_REPOS=your-org/your-repo

# Optional: filter issues/PRs by a milestone name instead of date range
# GITHUB_MILESTONE=Sprint 42

# ── Jira (optional — leave blank if not using) ────────────────────────────────
# JIRA_BASE_URL=https://your-org.atlassian.net
# JIRA_EMAIL=you@example.com
# JIRA_API_TOKEN=your_jira_api_token
# JIRA_PROJECT_KEY=ENG

# ── Linear (optional — leave blank if not using) ──────────────────────────────
# LINEAR_API_KEY=lin_api_your_key
# LINEAR_TEAM_ID=your-team-uuid

# ── Report settings ───────────────────────────────────────────────────────────
TEAM_NAME=Engineering
SPRINT_NAME=Week of $(date +%Y-%m-%d)

# Date range for "last N days" mode (default: 7). Ignored if GITHUB_MILESTONE is set.
LOOKBACK_DAYS=7

# Optional sprint goal shown in Report A header
# SPRINT_GOAL=Finish auth redesign and ship onboarding v2

# ── Slack (optional) ──────────────────────────────────────────────────────────
# POST_TO_SLACK=true
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/xxxx
